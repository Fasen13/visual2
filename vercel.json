{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api",
      "destination": "server.js"
    },
    {
      "source": "/product-evaluate",
      "destination": "server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
  ]
}  ],
  "routes": [
    {
      "src": "/(api|product-evaluate).*",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
